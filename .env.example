# ─── Model Paths ───────────────────────────────────────────────────────────────
MODEL_PATH=models/siamese_signature_model.h5
ENCODER_PATH=models/signature_encoder.h5

# ─── Inference Settings ────────────────────────────────────────────────────────
MATCH_THRESHOLD=0.5
IMG_SIZE=128
MAX_FILE_SIZE_MB=2

# ─── CORS (comma-separated) ───────────────────────────────────────────────────
# Dev:  http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
# Prod: https://YOUR_VERCEL_APP.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# ─── Training (ml/train.py only) ──────────────────────────────────────────────
CEDAR_ROOT=./CEDAR
TRAIN_EPOCHS=12
TRAIN_BATCH_SIZE=32
TRAIN_STEPS_PER_EPOCH=300
TRAIN_VALIDATION_STEPS=50
